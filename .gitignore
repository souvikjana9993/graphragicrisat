# Python Virtual Environments
venv/
.venv/
env/
.env

# Environment Variables (DO NOT COMMIT SECRETS)
.env
.env.local
.env.*

# Python Cache & Bytecode
__pycache__/
*.py[cod]
*$py.class

# Logs
*.log
data/*.log

# IDE & Editor Configs
.vscode/
.idea/
*.swp
*.swo

# Large Raw Data Directories & Backups (Keep out of source control)
data/*
*.zip
*.tar.gz
*.rar

