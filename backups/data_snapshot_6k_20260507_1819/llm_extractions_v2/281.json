    },
    {
      "name": "CONVENTIONAL METHOD",
      "type": "METHOD",
      "description": "Inoculation method where peat-based inoculum suspended in cellulose gum is thoroughly mixed with seeds.",
      "source_id": "paper_281"
    },
    {
      "name": "LIQUID METHOD",
      "type": "METHOD",
      "description": "Inoculation method where peat-based inoculum suspended in water is poured directly into the furrows.",
      "source_id": "paper_281"
    },
    {
      "name": "DIRECT PEAT PLACEMENT METHOD",
      "type": "METHOD",
      "description": "Inoculation method where peat-based inoculum mixed with soil is placed in the furrows.",
      "source_id": "paper_281"
    },
    {
